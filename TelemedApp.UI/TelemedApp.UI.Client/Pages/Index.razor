@page "/"
@using TelemedApp.UI.Client.Services
@using TelemedApp.UI.Client.Shared.Components.Buttons
@inject NavigationManager Navigation
@inject PermissionGuard Permission

<DashboardPage Header="@Header">

    <!-- Hero Section -->
    <section class="mb-16 text-center">
        <h1 class="mb-4 text-4xl font-bold">
            Welcome to <span class="text-blue-600 dark:text-blue-600">TelemedApp</span>
        </h1>

        <p class="mx-auto mb-8 max-w-2xl text-lg text-gray-600 dark:text-gray-600">
            A modern, elegant, and powerful platform for managing patients, doctors, appointments,
            and medical workflows — built with precision and clarity.
        </p>

        <div class="flex justify-center gap-4">

            @* If user can view Dashboard, show direct CTA *@
            @if (Permission.Has("Dashboard.View"))
            {
                <Button Variant="primary" Size="lg" OnClick="@GoToDashboard" Type="button">
                    Go to Dashboard
                </Button>
            }
            else
            {
                <Button Variant="primary" Size="lg" OnClick="@GoToLogin" Type="button">
                    Login to access Dashboard
                </Button>
            }

            @* If user can view Patients, enable CTA; otherwise keep it disabled *@
            <Button Variant="accent"
                    Size="lg"
                    OnClick="@GoToPatients"
                    Type="button"
                    Disabled="@( !Permission.Has("Patients.View") )">
                View Patients
            </Button>

        </div>
    </section>

    <!-- Features Grid -->
    <section class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">

        <FeatureCard Icon="fa-solid fa-calendar-check"
                     Title="Smart Scheduling"
                     Description="Manage appointments with clarity, speed, and precision." />

        <FeatureCard Icon="fa-solid fa-user-doctor"
                     Title="Doctor Management"
                     Description="Track active, inactive, and former doctors with clean dashboards." />

        <FeatureCard Icon="fa-solid fa-users"
                     Title="Patient Records"
                     Description="Keep patient information organized, searchable, and accessible." />

        <FeatureCard Icon="fa-solid fa-flask"
                     Title="Lab Results"
                     Description="Track pending and completed lab results with real-time updates." />

        <FeatureCard Icon="fa-solid fa-chart-line"
                     Title="Analytics"
                     Description="Get insights into appointments, doctor activity, and patient flow." />

        <FeatureCard Icon="fa-solid fa-shield-halved"
                     Title="Secure & Reliable"
                     Description="Built with modern technologies ensuring privacy and stability." />

    </section>

</DashboardPage>

@code {
    RenderFragment Header => @<DashboardHeader Title="TelemedApp"
                     Subtitle="A modern medical management platform"
                     Icon="fa-solid fa-house" />;

    Task GoToDashboard()
    {
        Navigation.NavigateTo("/dashboard");
        return Task.CompletedTask;
    }

    Task GoToPatients()
    {
        Navigation.NavigateTo("/patients");
        return Task.CompletedTask;
    }

    Task GoToLogin()
    {
        Navigation.NavigateTo("/login");
        return Task.CompletedTask;
    }
}