@namespace TelemedApp.UI.Client.Shared.Components.Modals

@if (Visible)
{
    <div class="fixed inset-0 z-40 flex">
        
        <!-- Overlay -->
        <div class="absolute inset-0 bg-black/40 backdrop-blur-sm transition-opacity duration-200"
             @onclick="OnClose">
        </div>

        <!-- Drawer Panel -->
        <div class="@DrawerClasses">
            @ChildContent
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }

    [Parameter] public string Position { get; set; } = "right"; // left, right, bottom

    private string DrawerClasses =>
        Position switch
        {
            "left" =>
                "relative w-80 h-full bg-white dark:bg-gray-900 shadow-xl backdrop-blur-sm " +
                "animate-slide-left rounded-r-xl",

            "bottom" =>
                "relative w-full h-80 bg-white dark:bg-gray-900 shadow-xl backdrop-blur-sm " +
                "animate-slide-up rounded-t-xl",

            _ =>
                "relative w-80 h-full bg-white dark:bg-gray-900 shadow-xl backdrop-blur-sm " +
                "animate-slide-right rounded-l-xl"
        };
}