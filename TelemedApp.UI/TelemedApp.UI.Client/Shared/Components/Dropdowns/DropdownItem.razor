@namespace TelemedApp.UI.Client.Shared.Components.Dropdowns

<button class="@ItemClasses" @onclick="HandleClick" disabled="@Disabled">
    @if (!string.IsNullOrWhiteSpace(Icon))
    {
        <i class="@Icon mr-2 text-sm opacity-80"></i>
    }

    <span>@Label</span>

    @if (!string.IsNullOrWhiteSpace(Shortcut))
    {
        <span class="ml-auto text-xs opacity-60">@Shortcut</span>
    }
</button>

@code {
    [CascadingParameter] public Dropdown? Parent { get; set; }
    [CascadingParameter] public bool IsDark { get; set; }

    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Icon { get; set; } = "";
    [Parameter] public string Shortcut { get; set; } = "";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    private string ItemClasses =>
        "w-full flex items-center gap-2 px-3 py-2 text-sm rounded-md transition " +
        (Disabled
            ? "opacity-40 cursor-not-allowed"
            : IsDark
                ? "hover:bg-gray-800 text-gray-200"
                : "hover:bg-gray-100 text-gray-700");

    private async Task HandleClick()
    {
        if (!Disabled)
        {
            await OnClick.InvokeAsync();
            Parent?.Close();
        }
    }
}