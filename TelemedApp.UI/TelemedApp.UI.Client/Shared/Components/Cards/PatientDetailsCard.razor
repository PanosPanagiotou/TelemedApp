@namespace TelemedApp.UI.Client.Shared.Components
@using TelemedApp.UI.Client.Shared.Components.Avatars
@using TelemedApp.UI.Client.Shared.Components.Cards

<Card Variant="default"
      CssClass="@CardCss"
      @onclick="HandleClick">

    <!-- Header -->
    <CardHeader Variant="@HeaderVariant">
        <div class="flex items-center gap-4">

            <Avatar Name="@Name" Size="@AvatarSize" />

            <div class="flex flex-col">
                <CardTitle Size="@TitleSize">@Name</CardTitle>

                <div class="@InfoRowClasses">

                    @if (!string.IsNullOrWhiteSpace(Gender))
                    {
                        <span>@Gender</span>
                    }

                    @if (Age is not null)
                    {
                        <span>• @Age years</span>
                    }

                    @if (!string.IsNullOrWhiteSpace(Status))
                    {
                        <span class="@StatusBadgeClass">@Status</span>
                    }
                </div>
            </div>

        </div>
    </CardHeader>

    <!-- Body -->
    <CardBody Variant="@BodyVariant">

        @if (!string.IsNullOrWhiteSpace(Email))
        {
            <div class="@ContactRowClasses">
                <i class="fa-solid fa-envelope text-gray-500"></i>
                <span>@Email</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Phone))
        {
            <div class="@ContactRowClasses">
                <i class="fa-solid fa-phone text-gray-500"></i>
                <span>@Phone</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Address))
        {
            <div class="@ContactRowClasses">
                <i class="fa-solid fa-location-dot text-gray-500"></i>
                <span>@Address</span>
            </div>
        }

    </CardBody>

    <!-- Footer -->
    @if (Actions is not null)
    {
        <CardFooter Align="start">
            <div class="flex flex-wrap gap-3">
                @Actions
            </div>
        </CardFooter>
    }

</Card>

@code {
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public int? Age { get; set; }
    [Parameter] public string? Gender { get; set; }
    [Parameter] public string? Email { get; set; }
    [Parameter] public string? Phone { get; set; }
    [Parameter] public string? Address { get; set; }
    [Parameter] public string? Status { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }

    // NEW
    [Parameter] public AvatarSize AvatarSize { get; set; } = AvatarSize.Lg;
    [Parameter] public bool Compact { get; set; } = false;
    [Parameter] public bool Clickable { get; set; } = false;
    [Parameter] public EventCallback OnClick { get; set; }

    private async Task HandleClick()
    {
        if (Clickable)
            await OnClick.InvokeAsync();
    }

    // Dynamic classes based on Compact mode
    private string CardCss =>
        Clickable
            ? "hover:shadow-md cursor-pointer transition-shadow"
            : "";

    private string HeaderVariant => Compact ? "tight" : "loose";
    private string BodyVariant => Compact ? "tight" : "loose";
    private string TitleSize => Compact ? "md" : "lg";

    private string InfoRowClasses =>
        Compact
            ? "flex items-center gap-2 text-xs text-gray-600 dark:text-gray-300"
            : "flex items-center gap-3 text-sm text-gray-600 dark:text-gray-300";

    private string ContactRowClasses =>
        Compact
            ? "flex items-center gap-2 text-xs"
            : "flex items-center gap-2 text-sm";

    string StatusBadgeClass =>
        Status?.ToLower() switch
        {
            "active" => "inline-block rounded-full bg-green-100 px-3 py-1 text-xs text-green-700 dark:bg-green-900 dark:text-green-200",
            "inactive" => "inline-block rounded-full bg-gray-200 px-3 py-1 text-xs text-gray-700 dark:bg-gray-800 dark:text-gray-300",
            "critical" => "inline-block rounded-full bg-red-100 px-3 py-1 text-xs text-red-700 dark:bg-red-900 dark:text-red-200",
            _ => "inline-block rounded-full bg-blue-100 px-3 py-1 text-xs text-blue-700 dark:bg-blue-900 dark:text-blue-200"
        };
}
