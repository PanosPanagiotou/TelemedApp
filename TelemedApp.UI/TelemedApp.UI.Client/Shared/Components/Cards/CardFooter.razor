<div class="@BuildClasses()">
    @ChildContent
</div>

@code {
    [Parameter] public string CssClass { get; set; } = "";
    [Parameter] public string Align { get; set; } = "start"; // start, center, end
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private string BuildClasses()
    {
        var baseClass =
            "mt-6 pt-4 border-t border-gray-200 dark:border-gray-700 flex";

        var alignClass = Align switch
        {
            "center" => "justify-center",
            "end" => "justify-end",
            _ => "justify-start"
        };

        return $"{baseClass} {alignClass} {CssClass}".Trim();
    }
}