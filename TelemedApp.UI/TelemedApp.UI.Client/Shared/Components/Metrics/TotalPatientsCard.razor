@using TelemedApp.UI.Client.Shared.Components.Metrics

<MetricCard Title="Total Patients"
            Value="@Count.ToString("N0")"
            Subtitle="@EffectiveSubtitle"
            Trend="up"
            Icon="fa-solid fa-users"
            Compact="@Compact"
            Clickable="@Clickable"
            OnClick="@OnClick" />

@code {
    [Parameter] public int Count { get; set; }
    [Parameter] public string? Subtitle { get; set; }

    // NEW
    [Parameter] public bool Compact { get; set; } = false;
    [Parameter] public bool Clickable { get; set; } = false;
    [Parameter] public EventCallback OnClick { get; set; }

    public string EffectiveSubtitle =>
        !string.IsNullOrWhiteSpace(Subtitle)
            ? Subtitle
            : "↑ 12% from last month";
}