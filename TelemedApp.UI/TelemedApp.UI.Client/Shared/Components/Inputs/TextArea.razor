@inherits InputBase
@inject IJSRuntime JS

<div class="flex flex-col gap-1">

    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <label class="text-sm font-medium @(IsDark ? "text-gray-200" : "text-gray-700")">
            @Label
        </label>
    }

    <textarea @ref="TextAreaRef"
              value="@Value"
              @oninput="OnInput"
              placeholder="@Placeholder"
              disabled="@Disabled"
              class="@BuildTextAreaClasses()">
    </textarea>

    @if (!string.IsNullOrWhiteSpace(HelperText))
    {
        <span class="text-xs @(IsDark ? "text-gray-400" : "text-gray-600")">
            @HelperText
        </span>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string Placeholder { get; set; } = "";
    [Parameter] public string HelperText { get; set; } = "";

    [Parameter] public string Value { get; set; } = "";
    [Parameter] public EventCallback<string> ValueChanged { get; set; }

    private ElementReference TextAreaRef;

    private async Task OnInput(ChangeEventArgs e)
    {
        Value = e.Value?.ToString() ?? "";
        await ValueChanged.InvokeAsync(Value);
        await JS.InvokeVoidAsync("textareaAutoResize", TextAreaRef);
    }

    private string BuildTextAreaClasses()
        => $"{BuildClasses()} resize-none overflow-hidden";
}