<div class="@ToolbarClasses">
    @ChildContent
</div>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string Gap { get; set; } = "3";
    [Parameter] public bool Wrap { get; set; } = false;
    [Parameter] public string Align { get; set; } = "start"; // start, center, end

    private string ToolbarClasses =>
        $"{(Wrap ? "flex flex-wrap" : "flex")} items-center gap-{Gap} justify-{Align}";
}