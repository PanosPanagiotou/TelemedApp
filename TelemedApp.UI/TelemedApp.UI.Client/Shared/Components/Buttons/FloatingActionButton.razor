<button @onclick="OnClick"
        class="@BuildClasses()">
    @ChildContent
</button>

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    [Parameter] public string Variant { get; set; } = "primary";
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public bool Pulse { get; set; } = false;

    private string BuildClasses()
    {
        var sizeClass = Size switch
        {
            "sm" => "h-10 w-10",
            "lg" => "h-16 w-16",
            _ => "h-14 w-14"
        };

        var variantClass = Variant switch
        {
            "accent" => "bg-purple-600 hover:bg-purple-700",
            "danger" => "bg-red-600 hover:bg-red-700",
            _ => "bg-blue-600 hover:bg-blue-700"
        };

        var pulseClass = Pulse ? "animate-pulse" : "";

        return $"fixed bottom-6 right-6 flex items-center justify-center rounded-full text-white shadow-lg transition {sizeClass} {variantClass} {pulseClass}";
    }
}