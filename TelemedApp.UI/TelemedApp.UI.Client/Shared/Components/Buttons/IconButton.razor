<button @onclick="OnClick"
        disabled="@Disabled"
        class="@BuildClasses()">
    @ChildContent
</button>

@code {
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Variant { get; set; } = "ghost";
    [Parameter] public string Size { get; set; } = "md";
    [Parameter] public string Rounded { get; set; } = "lg";
    [Parameter] public bool Shadow { get; set; } = false;
    [Parameter] public bool ActiveScale { get; set; } = false;

    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    private string BuildClasses()
    {
        var sizeClass = Size switch
        {
            "sm" => "p-1.5",
            "lg" => "p-3",
            _ => "p-2"
        };

        var roundedClass = Rounded switch
        {
            "full" => "rounded-full",
            "md" => "rounded-md",
            _ => "rounded-lg"
        };

        var variantClass = Variant switch
        {
            "primary" => "bg-blue-600 text-white hover:bg-blue-700",
            "outline" => "border border-gray-300 dark:border-gray-600 hover:bg-gray-100 dark:hover:bg-gray-700",
            _ => "hover:bg-gray-100 dark:hover:bg-gray-700"
        };

        var shadowClass = Shadow ? "shadow-sm dark:shadow-gray-900/40" : "";
        var activeClass = ActiveScale ? "active:scale-95" : "";

        return $"inline-flex items-center justify-center transition disabled:opacity-50 {sizeClass} {roundedClass} {variantClass} {shadowClass} {activeClass}";
    }
}